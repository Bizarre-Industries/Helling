# Local runtime state stays out of commits.
.codex/.last-shipped-tag
.codex/council-logs/
.codex/settings.local.json
.codex/worktrees/

# autoskills install dir — source of truth lives upstream; we deploy real
# copies into .claude/skills/ which Claude Code reads. Re-sync via
# `cp -RL .agents/skills/. .claude/skills/` after running the autoskills tool.
.agents/
.claude-cache/
.claude-plans/
.design-fetch/
.remember/
.task/
